<?xml version="1.0" encoding="utf-8"?>
<!--
    Allow cleartext (ws://, http://) traffic to the ESP32 AP address only.
    All other traffic must use TLS. This is required because the device
    does not support TLS on its WebSocket server.
-->
<network-security-config>
    <!-- Allow cleartext traffic globally since the ESP32 web socket server 
         on the local network may be dynamically assigned and doesn't support TLS. -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
