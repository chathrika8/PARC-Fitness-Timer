<?xml version="1.0" encoding="utf-8"?>
<!--
    Allow cleartext (ws://) traffic to the ESP32 device.
    The device does not support TLS on its WebSocket server.
    Android's domain-config does not support IP wildcards, so cleartext is
    permitted globally — this app only ever opens connections to the local
    timer device and never sends traffic to the internet unencrypted.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
