<?xml version="1.0" encoding="utf-8"?>
<!--
    The ESP32 WebSocket server does not support TLS, so cleartext (ws://) is
    required to talk to it. Network security config <domain> elements do not
    accept CIDR ranges, and users may configure the timer at any LAN IP, so we
    cannot scope this any tighter than "all traffic". This is acceptable given
    the app only ever talks to the local timer; no credentials or PII are sent
    to any other host.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
